package fuchsia:actor@0.1.0;

/// Host-provided emit interface. Components call `send`/`send-to` to push a
/// typed payload to downstream actors via the per-edge mpsc channels the host
/// owns. Each emission goes only to the successors wired to the *named output
/// port* it was emitted on — not to every outgoing edge; a port may still have
/// several edges, so fan-out within a port is preserved.
interface emit {
  use types.{payload};

  /// Send a typed payload on a named output port (`out`, `true`, `case-a`, …).
  /// Only the successors wired to `port` receive it. Returns `Err` if the
  /// emission cannot be routed; components typically propagate the error out of
  /// `handle`, which ends the actor.
  send-to: func(port: string, msg: payload) -> result<_, string>;

  /// Send a typed payload on the default `out` port — convenience for
  /// `send-to("out", msg)`. Existing components that only call `send` keep
  /// working unchanged.
  send: func(msg: payload) -> result<_, string>;
}
